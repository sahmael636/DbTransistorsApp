<!-- Views/TransistorListPage.xaml -->
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:DbTransistorsApp.ViewModels"
             x:Class="DbTransistorsApp.Views.TransistorListPage"
             x:DataType="viewmodels:TransistorListViewModel"
             Title="{Binding Title}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Filtros -->
        <Border Grid.Row="0" 
                BackgroundColor="#F5F5F5"
                Padding="10"
                StrokeThickness="0"
                Stroke="#E0E0E0">

            <StackLayout Spacing="8">
                <Label Text="🔍 Filtros de búsqueda" 
                       FontSize="16" 
                       FontAttributes="Bold"
                       TextColor="#333333"/>

                <CollectionView ItemsSource="{Binding FilterFields}"
                                ItemsLayout="VerticalGrid, 2"
                                ItemSizingStrategy="MeasureAllItems">

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="viewmodels:FilterField">
                            <Border Padding="5" StrokeThickness="0">
                                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="2">
                                    <Label Grid.Row="0" 
                                           Text="{Binding DisplayName}" 
                                           FontSize="12" 
                                           FontAttributes="Bold"/>

                                    <Grid Grid.Row="1" ColumnDefinitions="*,Auto,*">
                                        <Entry Grid.Column="0"
                                               Text="{Binding MinValue}"
                                               Placeholder="De"
                                               Keyboard="Numeric"
                                               FontSize="12"
                                               BackgroundColor="White"
                                               HorizontalOptions="Fill"/>

                                        <Label Grid.Column="1" 
                                               Text=" - " 
                                               FontSize="12" 
                                               HorizontalOptions="Center"/>

                                        <Entry Grid.Column="2"
                                               Text="{Binding MaxValue}"
                                               Placeholder="Hasta"
                                               Keyboard="Numeric"
                                               FontSize="12"
                                               BackgroundColor="White"/>
                                    </Grid>

                                    <Label Grid.Row="2" 
                                           Text="{Binding Unit}" 
                                           FontSize="10" 
                                           TextColor="Gray"
                                           HorizontalOptions="End"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    <Button Grid.Column="0"
                            Text="🔍 Aplicar Filtros"
                            BackgroundColor="#2196F3"
                            TextColor="White"
                            FontSize="14"
                            Command="{Binding ApplyFiltersCommand}"/>

                    <Button Grid.Column="1"
                            Text="🔄 Limpiar Filtros"
                            BackgroundColor="#FF5722"
                            TextColor="White"
                            FontSize="14"
                            Command="{Binding ClearFiltersCommand}"/>
                </Grid>
            </StackLayout>
        </Border>

        <!-- Contador y tabla -->
        <Grid Grid.Row="1" 
              Padding="10,5"
              BackgroundColor="#E3F2FD">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Label Grid.Column="0" 
                   Text="{Binding TotalMatches, StringFormat='Total: {0} transistores'}" 
                   FontSize="14"
                   FontAttributes="Bold"/>

            <Label Grid.Column="1" 
                   Text="{Binding TableDisplayName}" 
                   FontSize="12"
                   TextColor="Gray"/>
        </Grid>

        <!-- Tabla de transistores -->
        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Transistors}"
                        SelectionMode="Single"
                        IsBusy="{Binding IsBusy}">

            <CollectionView.Header>
                <Grid Padding="10" 
                      BackgroundColor="#2196F3"
                      ColumnDefinitions="{Binding HeaderColumns}">
                    <!-- Encabezados dinámicos -->
                    <CollectionView ItemsSource="{Binding HeaderFields}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Label Text="{Binding .}" 
                                       TextColor="White" 
                                       FontAttributes="Bold"
                                       FontSize="14"
                                       HorizontalOptions="Center"/>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
            </CollectionView.Header>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="5" 
                          ColumnDefinitions="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:TransistorListViewModel}}, Path=ColumnDefinitions}"
                          BackgroundColor="{Binding BackgroundColor}">

                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:TransistorListViewModel}}, Path=SelectTransistorCommand}"
                                                  CommandParameter="{Binding .}"/>
                        </Grid.GestureRecognizers>

                        <!-- Campos dinámicos -->
                        <CollectionView ItemsSource="{Binding DisplayFields}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Label Text="{Binding .}" 
                                           FontSize="13"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"
                                           LineBreakMode="TailTruncation"/>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>