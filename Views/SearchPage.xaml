<!-- Views/SearchPage.xaml -->
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:DbTransistorsApp.ViewModels"
             x:Class="DbTransistorsApp.Views.SearchPage"
             x:DataType="viewmodels:SearchViewModel"
             Title="Buscar Transistor">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Barra de búsqueda -->
        <Border Grid.Row="0" 
                BackgroundColor="#2196F3"
                Padding="15,10">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Label Text="🔍"
                       TextColor="White"
                       FontSize="20"
                       VerticalOptions="Center"/>

                <Entry Grid.Column="1"
                       Text="{Binding SearchTerm}"
                       Placeholder="Buscar transistor..."
                       BackgroundColor="White"
                       TextColor="Black"
                       Margin="10,0"
                       VerticalOptions="Center"/>

                <Label Grid.Column="2"
                       Text="{Binding TotalMatches, StringFormat='{0} coincidencias'}"
                       TextColor="White"
                       FontSize="14"
                       VerticalOptions="Center"/>
            </Grid>
        </Border>

        <!-- Lista de resultados -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding SearchResults}"
                        SelectionMode="Single"
                        SelectedItem="{Binding SelectedItem}"
                        IsBusy="{Binding IsBusy}">

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="viewmodels:ByNameItem">
                    <Grid Padding="10" 
                          ColumnDefinitions="*,Auto,Auto"
                          BackgroundColor="{Binding BackgroundColor}">

                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:SearchViewModel}}, Path=SelectTransistorCommand}"
                                                  CommandParameter="{Binding .}"/>
                        </Grid.GestureRecognizers>

                        <Label Grid.Column="0"
                               Text="{Binding Name}"
                               FontSize="16"
                               FontAttributes="Bold"/>

                        <Label Grid.Column="1"
                               Text="{Binding Type}"
                               FontSize="14"
                               TextColor="Gray"/>

                        <Label Grid.Column="2"
                               Text="{Binding Idx}"
                               FontSize="12"
                               TextColor="Gray"
                               Margin="10,0,0,0"/>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>