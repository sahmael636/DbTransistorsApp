<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:DbTransistorsApp.ViewModels"
             xmlns:models="clr-namespace:DbTransistorsApp.Models.Base"
             x:Class="DbTransistorsApp.Views.EstructurasPage"
             x:Name="ThisPage"
             x:DataType="viewmodels:EstructurasViewModel"
             Title="{Binding Title}"
             IsBusy="{Binding IsBusy}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Lista de estructuras -->
        <RefreshView Grid.Row="0"
                     IsRefreshing="{Binding IsBusy}"
                     Command="{Binding RefreshCommand}">
            <CollectionView ItemsSource="{Binding Estructuras}">

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Estructura">
                        <Grid Padding="10" 
                              ColumnDefinitions="*,Auto,Auto"
                              BackgroundColor="{Binding BackgroundColor}">

                            <Label Grid.Column="0" 
                                   Text="{Binding Nombre}" 
                                   FontSize="16"
                                   VerticalOptions="Center"/>

                            <Button Grid.Column="1"
                                    Text="✏️"
                                    BackgroundColor="Transparent"
                                    TextColor="#2196F3"
                                    FontSize="18"
                                    Command="{Binding BindingContext.EditEstructuraCommand, Source={x:Reference ThisPage}}"
                                    CommandParameter="{Binding .}"
                                    VerticalOptions="Center"
                                    Margin="0,0,5,0"/>

                            <Button Grid.Column="2"
                                    Text="🗑️"
                                    BackgroundColor="Transparent"
                                    TextColor="#F44336"
                                    FontSize="18"
                                    Command="{Binding BindingContext.DeleteEstructuraCommand, Source={x:Reference ThisPage}}"
                                    CommandParameter="{Binding .}"
                                    VerticalOptions="Center"/>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <!-- Botón flotante -->
        <Button Grid.Row="0"
                Text="➕"
                BackgroundColor="#4CAF50"
                TextColor="White"
                FontSize="24"
                WidthRequest="60"
                HeightRequest="60"
                CornerRadius="30"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="20"
                Command="{Binding NewEstructuraCommand}"/>
    </Grid>
</ContentPage>