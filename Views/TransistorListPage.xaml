<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:DbTransistorsApp.ViewModels"
             xmlns:converters="clr-namespace:DbTransistorsApp.Converters"
             x:Class="DbTransistorsApp.Views.TransistorListPage"
             x:Name="ThisPage"

             Title="{Binding Title}">

    <ContentPage.Resources>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
    </ContentPage.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Filtros -->
        <Border Grid.Row="0" 
                BackgroundColor="#F5F5F5"
                Padding="10"
                StrokeThickness="0"
                Stroke="#E0E0E0">

            <StackLayout Spacing="8">
                <Label Text="🔍 Filtros de búsqueda" 
                       FontSize="16" 
                       FontAttributes="Bold"
                       TextColor="#333333"/>

                <CollectionView ItemsSource="{Binding FilterFields}"
                                ItemsLayout="VerticalGrid, 2"
                                ItemSizingStrategy="MeasureAllItems">

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="viewmodels:FilterField">
                            <Border Padding="5" StrokeThickness="0">
                                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="2">
                                    <Label Grid.Row="0" 
                                           Text="{Binding DisplayName}" 
                                           FontSize="12" 
                                           FontAttributes="Bold"/>

                                    <Grid Grid.Row="1" ColumnDefinitions="*,Auto,*">
                                        <Entry Grid.Column="0"
                                               Text="{Binding MinValue}"
                                               Placeholder="De"
                                               Keyboard="Numeric"
                                               FontSize="12"
                                               BackgroundColor="White"
                                               HorizontalOptions="Fill"/>

                                        <Label Grid.Column="1" 
                                               Text=" - " 
                                               FontSize="12" 
                                               HorizontalOptions="Center"/>

                                        <Entry Grid.Column="2"
                                               Text="{Binding MaxValue}"
                                               Placeholder="Hasta"
                                               Keyboard="Numeric"
                                               FontSize="12"
                                               BackgroundColor="White"/>
                                    </Grid>

                                    <Label Grid.Row="2" 
                                           Text="{Binding Unit}" 
                                           FontSize="10" 
                                           TextColor="Gray"
                                           HorizontalOptions="End"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    <Button Grid.Column="0"
                            Text="🔍 Aplicar Filtros"
                            BackgroundColor="#2196F3"
                            TextColor="White"
                            FontSize="14"
                            Command="{Binding ApplyFiltersCommand}"/>

                    <Button Grid.Column="1"
                            Text="🔄 Limpiar Filtros"
                            BackgroundColor="#FF5722"
                            TextColor="White"
                            FontSize="14"
                            Command="{Binding ClearFiltersCommand}"/>
                </Grid>
            </StackLayout>
        </Border>

        <!-- Contador -->
        <Grid Grid.Row="1" 
              Padding="10,5"
              BackgroundColor="#E3F2FD">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Label Grid.Column="0" 
                   Text="{Binding TotalMatches, StringFormat='Total: {0} transistores'}" 
                   FontSize="14"
                   FontAttributes="Bold"/>

            <Label Grid.Column="1" 
                   Text="{Binding TableDisplayName}" 
                   FontSize="12"
                   TextColor="Gray"/>
        </Grid>

        <!-- Grid para CollectionView + ActivityIndicator -->
        <Grid Grid.Row="2">
            <!-- Tabla de transistores - SIN IsBusy -->
            <CollectionView ItemsSource="{Binding Transistors}"
                            SelectionMode="Single"
                            IsVisible="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}">

                <CollectionView.Header>
                    <Grid Padding="10" 
                          BackgroundColor="#2196F3"
                          ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto,Auto">
                        <Label Grid.Column="0" Text="Nombre" TextColor="White" FontAttributes="Bold" FontSize="12"/>
                        <Label Grid.Column="1" Text="Pc" TextColor="White" FontAttributes="Bold" FontSize="12"/>
                        <Label Grid.Column="2" Text="VCE" TextColor="White" FontAttributes="Bold" FontSize="12"/>
                        <Label Grid.Column="3" Text="VCB" TextColor="White" FontAttributes="Bold" FontSize="12"/>
                        <Label Grid.Column="4" Text="IC" TextColor="White" FontAttributes="Bold" FontSize="12"/>
                        <Label Grid.Column="5" Text="Ft" TextColor="White" FontAttributes="Bold" FontSize="12"/>
                        <Label Grid.Column="6" Text="Hfe" TextColor="White" FontAttributes="Bold" FontSize="12"/>
                    </Grid>
                </CollectionView.Header>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="5" 
                              ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto,Auto">

                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding BindingContext.SelectTransistorCommand, Source={x:Reference ThisPage}}"
                                                      CommandParameter="{Binding .}"/>
                            </Grid.GestureRecognizers>

                            <Label Grid.Column="0" Text="{Binding Name}" FontSize="12"/>
                            <Label Grid.Column="1" Text="{Binding Pc}" FontSize="12" HorizontalOptions="Center"/>
                            <Label Grid.Column="2" Text="{Binding Vce}" FontSize="12" HorizontalOptions="Center"/>
                            <Label Grid.Column="3" Text="{Binding Vcb}" FontSize="12" HorizontalOptions="Center"/>
                            <Label Grid.Column="4" Text="{Binding Ic}" FontSize="12" HorizontalOptions="Center"/>
                            <Label Grid.Column="5" Text="{Binding Ft}" FontSize="12" HorizontalOptions="Center"/>
                            <Label Grid.Column="6" Text="{Binding Hfe}" FontSize="12" HorizontalOptions="Center"/>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- ActivityIndicator para carga -->
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
        </Grid>
    </Grid>
</ContentPage>