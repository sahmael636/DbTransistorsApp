<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DbTransistorsApp.Views.ImagePopup"
             BackgroundColor="#80000000">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <Label Grid.Row="0" 
               Text="{Binding Title}" 
               TextColor="White" 
               FontSize="18" 
               FontAttributes="Bold"
               HorizontalOptions="Center"
               Margin="0,20,0,10"/>

        <!-- Imagen -->
        <Image Grid.Row="1" 
               Source="{Binding ImagePath}" 
               Aspect="AspectFit"
               HorizontalOptions="Center"
               VerticalOptions="Center"/>

        <!-- Botón de cierre -->
        <Button Grid.Row="2" 
                Text="Cerrar" 
                BackgroundColor="#2196F3"
                TextColor="White"
                FontSize="16"
                HorizontalOptions="Center"
                WidthRequest="200"
                Command="{Binding CloseCommand}"
                Margin="0,10,0,30"/>
    </Grid>
</ContentPage>