<!-- Views/EncapsuladosPage.xaml -->
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:DbTransistorsApp.ViewModels"
             x:Class="DbTransistorsApp.Views.EncapsuladosPage"
             x:DataType="viewmodels:EncapsuladosViewModel"
             Title="{Binding Title}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Lista de encapsulados -->
        <CollectionView Grid.Row="0"
                        ItemsSource="{Binding Encapsulados}"
                        IsBusy="{Binding IsBusy}">

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Encapsulado">
                    <Grid Padding="10" 
                          ColumnDefinitions="*,Auto,Auto"
                          BackgroundColor="{Binding BackgroundColor}">

                        <Grid Grid.Column="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" 
                                    WidthRequest="40" 
                                    HeightRequest="40"
                                    CornerRadius="5"
                                    BackgroundColor="#E0E0E0"
                                    Margin="0,0,10,0">

                                <Image Source="{Binding ImagenPreview}" 
                                       Aspect="AspectFit"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>

                            <Label Grid.Column="1" 
                                   Text="{Binding Nombre}" 
                                   FontSize="16"
                                   VerticalOptions="Center"/>
                        </Grid>

                        <Button Grid.Column="1"
                                Text="✏️"
                                BackgroundColor="Transparent"
                                TextColor="#2196F3"
                                FontSize="18"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:EncapsuladosViewModel}}, Path=EditEncapsuladoCommand}"
                                CommandParameter="{Binding .}"
                                VerticalOptions="Center"
                                Margin="0,0,5,0"/>

                        <Button Grid.Column="2"
                                Text="🗑️"
                                BackgroundColor="Transparent"
                                TextColor="#F44336"
                                FontSize="18"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:EncapsuladosViewModel}}, Path=DeleteEncapsuladoCommand}"
                                CommandParameter="{Binding .}"
                                VerticalOptions="Center"/>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Botón flotante -->
        <Button Grid.Row="0"
                Text="➕"
                BackgroundColor="#4CAF50"
                TextColor="White"
                FontSize="24"
                WidthRequest="60"
                HeightRequest="60"
                CornerRadius="30"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="20"
                Command="{Binding NewEncapsuladoCommand}"/>
    </Grid>
</ContentPage>